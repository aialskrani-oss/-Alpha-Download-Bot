# ===================================================
  # Alpha Downloader Bot - متغيرات البيئة المطلوبة
  # انسخ هذا الملف إلى .env وأضف قيمك الحقيقية
  # Copy this file to .env and fill in your values
  # ===================================================

  # [مطلوب / REQUIRED] توكن البوت من @BotFather على تيليجرام
  TELEGRAM_BOT_TOKEN=your_bot_token_here

  # [اختياري / OPTIONAL] كوكيز Facebook بصيغة Netscape للمحتوى الخاص
  # Optional: Facebook cookies in Netscape format for private/restricted videos
  # كيفية الحصول عليها / How to get them:
  #   1. ثبّت "Get cookies.txt LOCALLY" على Chrome أو Firefox
  #   2. سجّل دخولك على facebook.com
  #   3. صدّر الكوكيز وانسخ المحتوى كاملاً هنا
  FACEBOOK_COOKIES=

  # [اختياري / OPTIONAL] منفذ خادم keep-alive (الافتراضي: 5001)
  # Optional: Port for the keep-alive Flask server (default: 5001)
  KEEP_ALIVE_PORT=5001

  # [اختياري / OPTIONAL] رابط التطبيق الخارجي لـ self-ping
  # Optional: External URL of your app for self-ping (prevents sleep on free tiers)
  # مثال / Example: https://your-app.onrender.com
  RENDER_EXTERNAL_URL=

  # ملاحظة / Note:
  # Instagram يعمل بدون بيانات دخول للمحتوى العام تلقائياً.
  # Instagram public content works without any login credentials — no setup needed.
  