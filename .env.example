# ===================================================
# Alpha Downloader Bot - متغيرات البيئة المطلوبة
# انسخ هذا الملف إلى .env وأضف قيمك الحقيقية
# ===================================================

# [مطلوب] توكن البوت من @BotFather على تيليجرام
TELEGRAM_BOT_TOKEN=your_bot_token_here

# [اختياري] بيانات دخول Instagram لتفعيل التحميل التلقائي
# استخدم حساباً ثانوياً وليس حسابك الشخصي
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=

# [اختياري] كوكيز Facebook بصيغة Netscape للتحميل
# يمكنك تصدير الكوكيز من متصفحك باستخدام إضافة "Get cookies.txt LOCALLY"
FACEBOOK_COOKIES=

# [اختياري] منفذ خادم keep-alive (الافتراضي: 5001)
KEEP_ALIVE_PORT=5001
